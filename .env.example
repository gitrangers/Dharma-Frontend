# Legacy Sails API (home slider, videos, etc. — movie grids use Strapi only)
NEXT_PUBLIC_API_URL=http://localhost:1337/api/
# API_URL=

# Strapi — `STRAPI_URL` used for `/api/dharma-sliders` (videos hero) even without token when public;
# movies grid still requires `STRAPI_API_TOKEN`.
STRAPI_URL=https://dharmacms2.tinglabs.in
STRAPI_API_TOKEN=
# Also accepted: STRAPI_AUTH_TOKEN= or STRAPI_TOKEN= (same JWT)

# Optional — client-only image helper: same host as STRAPI_URL for relative /uploads paths
# NEXT_PUBLIC_STRAPI_URL=

# Optional — legacy Sails upload reader (must end with readFile for ?file=... queries)
# NEXT_PUBLIC_UPLOAD_BASE=
