# Strapi API
STRAPI_URL=https://dharmacms2.tinglabs.in
STRAPI_API_TOKEN=
# Also accepted: STRAPI_AUTH_TOKEN= or STRAPI_TOKEN= (same JWT)

# Optional — client-only image helper: same host as STRAPI_URL for relative /uploads paths
# NEXT_PUBLIC_STRAPI_URL=

# Optional upload reader (must end with readFile for ?file=... queries)
# NEXT_PUBLIC_UPLOAD_BASE=

# Maps API (Contact page — restricts key to localhost + prod domains & Maps JavaScript API)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
